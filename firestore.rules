rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['rollNumber', 'name', 'department', 'semester', 'cgpa', 'createdAt', 'updatedAt'])
        && data.keys().size() == 7
        && data.rollNumber is int
        && data.name is string && data.name.size() >= 2 && data.name.size() <= 100
        && data.department is string && data.department.size() >= 1 && data.department.size() <= 50
        && data.semester is int && data.semester >= 1 && data.semester <= 8
        && (data.cgpa is float || data.cgpa is int) && data.cgpa >= 0.0 && data.cgpa <= 10.0
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidUpdate(data, existing) {
      return data.keys().hasAll(['rollNumber', 'name', 'department', 'semester', 'cgpa', 'createdAt', 'updatedAt'])
        && data.rollNumber == existing.rollNumber
        && data.createdAt == existing.createdAt
        && data.updatedAt == request.time
        && data.name is string && data.name.size() >= 2
        && data.department is string
        && data.semester is int
        && (data.cgpa is float || data.cgpa is int);
    }

    match /students/{studentId} {
      allow read: if true; // Allow public read for this SIS demo
      allow create: if isSignedIn() && isValidStudent(request.resource.data);
      allow update: if isSignedIn() && isValidUpdate(request.resource.data, resource.data);
      allow delete: if isSignedIn();
    }
  }
}
